{
  "name": "fvnky-discord-bot",
  "version": "1.0.0",
  "description": "Discord Music Bot System",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"console.log('postinstall ok')\"",
    "server": "node server/index.js",
    "client": "npm run dev --prefix client",
    "web": "concurrently \"npm run server\" \"npm run client\"",
